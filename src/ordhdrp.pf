     A          R ORDHEDR                    TEXT('Order Header')
     A            ORDNO          8P 0        COLHDG('Order' 'Number')
     A                                       TEXT('Order Number')
     A            CUSTNO         6P 0        COLHDG('Cust' 'Number')
     A                                       TEXT('Customer Number')
     A            ORDDATE        8S 0        COLHDG('Order' 'Date')
     A                                       TEXT('Order Date YYYYMMDD')
     A            ORDSTAT        1A          COLHDG('Status')
     A                                       TEXT('Order Status P/S/C/X')
     A            SHIPDATE       8S 0        COLHDG('Ship' 'Date')
     A                                       TEXT('Ship Date YYYYMMDD')
     A            SHIPVIA        2A          COLHDG('Ship' 'Via')
     A                                       TEXT('Shipping Method')
     A            ORDTOTAL      11P 2        COLHDG('Order' 'Total')
     A                                       TEXT('Order Total Amount')
     A            TAXTOTAL       9P 2        COLHDG('Tax' 'Total')
     A                                       TEXT('Tax Total')
     A            SHIPTOTAL      9P 2        COLHDG('Shipping' 'Total')
     A                                       TEXT('Shipping Total')
     A            PONUMBER      20A          COLHDG('PO Number')
     A                                       TEXT('Purchase Order Number')
     A            SLSPERSON      6A          COLHDG('Sales' 'Person')
     A                                       TEXT('Salesperson Code')
     A            CREATETIME    14S 0        COLHDG('Created' 'Timestamp')
     A                                       TEXT('Created Timestamp')
     A          K ORDNO
