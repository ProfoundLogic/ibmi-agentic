     A          R CUSMSTR                    TEXT('Customer Master')
     A            CUSTNO         6P 0        COLHDG('Cust' 'Number')
     A                                       TEXT('Customer Number')
     A            CNAME         40A          COLHDG('Customer Name')
     A                                       TEXT('Customer Name')
     A            CADDR1        40A          COLHDG('Address' 'Line 1')
     A                                       TEXT('Address Line 1')
     A            CADDR2        40A          COLHDG('Address' 'Line 2')
     A                                       TEXT('Address Line 2')
     A            CCITY         30A          COLHDG('City')
     A                                       TEXT('City')
     A            CSTATE         2A          COLHDG('State')
     A                                       TEXT('State Code')
     A            CZIP          10A          COLHDG('Zip Code')
     A                                       TEXT('Zip/Postal Code')
     A            CPHONE        15A          COLHDG('Phone')
     A                                       TEXT('Phone Number')
     A            CEMAIL        60A          COLHDG('Email')
     A                                       TEXT('Email Address')
     A            CSTATUS        1A          COLHDG('Status')
     A                                       TEXT('Customer Status A/I/S')
     A            CTYPE          1A          COLHDG('Type')
     A                                       TEXT('Customer Type R/B')
     A            CLIMIT        11P 2        COLHDG('Credit' 'Limit')
     A                                       TEXT('Credit Limit')
     A            CBALANCE      11P 2        COLHDG('Current' 'Balance')
     A                                       TEXT('Current Balance')
     A            CLASTORD       8S 0        COLHDG('Last Order' 'Date')
     A                                       TEXT('Last Order Date YYYYMMDD')
     A            CCREATED       8S 0        COLHDG('Date' 'Created')
     A                                       TEXT('Date Created YYYYMMDD')
     A          K CUSTNO
