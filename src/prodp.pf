     A          R PRDMSTR                    TEXT('Product Master Record')
     A            ITEMNO        15A          COLHDG('Item' 'Number')
     A                                       TEXT('Item Number')
     A            ITEMDESC      60A          COLHDG('Description')
     A                                       TEXT('Item Description')
     A            CATEGORY      10A          COLHDG('Category')
     A                                       TEXT('Product Category')
     A            UNITPRICE      9P 2        COLHDG('Unit' 'Price')
     A                                       TEXT('Unit Price')
     A            UNITCOST       9P 2        COLHDG('Unit' 'Cost')
     A                                       TEXT('Unit Cost')
     A            QTYONHAND      7P 0        COLHDG('Qty On' 'Hand')
     A                                       TEXT('Quantity On Hand')
     A            QTYALLOC       7P 0        COLHDG('Qty' 'Allocated')
     A                                       TEXT('Quantity Allocated')
     A            REORDPT        7P 0        COLHDG('Reorder' 'Point')
     A                                       TEXT('Reorder Point')
     A            REORDQTY       7P 0        COLHDG('Reorder' 'Quantity')
     A                                       TEXT('Reorder Quantity')
     A            VENDOR        10A          COLHDG('Vendor')
     A                                       TEXT('Vendor Code')
     A            ITEMSTAT       1A          COLHDG('Status')
     A                                       TEXT('Item Status A/D')
     A            LASTUPDT       8S 0        COLHDG('Last' 'Updated')
     A                                       TEXT('Last Updated YYYYMMDD')
     A          K ITEMNO
