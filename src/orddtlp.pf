     A          R ORDDTLR                    TEXT('Order Line Item Record')
     A            ORDNO          8P 0        COLHDG('Order' 'Number')
     A                                       TEXT('Order Number')
     A            LINENO         3P 0        COLHDG('Line' 'Number')
     A                                       TEXT('Line Number')
     A            ITEMNO        15A          COLHDG('Item' 'Number')
     A                                       TEXT('Item Number')
     A            QTYORD         7P 2        COLHDG('Qty' 'Ordered')
     A                                       TEXT('Quantity Ordered')
     A            QTYSHIP        7P 2        COLHDG('Qty' 'Shipped')
     A                                       TEXT('Quantity Shipped')
     A            UNITPRICE      9P 2        COLHDG('Unit' 'Price')
     A                                       TEXT('Unit Price')
     A            DISCOUNT       5P 2        COLHDG('Discount' '%')
     A                                       TEXT('Discount Percentage')
     A            EXTPRICE      11P 2        COLHDG('Extended' 'Price')
     A                                       TEXT('Extended Price')
     A            BACKORDER      1A          COLHDG('Back' 'Order')
     A                                       TEXT('Backorder Flag Y/N')
     A          K ORDNO
     A          K LINENO
