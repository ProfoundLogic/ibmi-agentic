    {
      "apiRouteID": "c4d2f1a8-9e6b-4f3c-8d2a-1b5c7e9f0a44",
      "name": "Typeahead",
      "enableCors": true,
      "summary": "Typeahead suggestions for tenants",
      "description": "Returns up to 10 matching tenants in the JSON shape required by the Profound UI textbox 'choices URL' (autocomplete) feature: { success, response: { results, colWidths } }. Profound UI sends the user's typed text automatically as the 'query' query-string parameter. Configure the textbox 'choice values field' to 'tguid' so that selecting a row returns the tenant GUID to the bound field. Searches against last name, first name, address line 1, city, last 4 of SSN, and the digits of the phone number (spaces and non-digit characters are ignored when matching the phone).",
      "method": "post",
      "tag": "tenantps",
      "path": "/tenantps/typeahead",
      "outputdescription": "Returns autocomplete suggestions in the Profound UI 'choices URL' JSON format.",
      "inputs": [
        {
          "type": "string",
          "from": "query",
          "name": "query",
          "required": false,
          "description": "Text typed by the user. Sent automatically as 'query' by the Profound UI textbox 'choices URL' feature. Matched against last name, first name, address line 1, city, last 4 of SSN, and digits of the phone number."
        },
        {
          "type": "integer",
          "from": "query",
          "name": "limit",
          "description": "Maximum number of suggestions to return. Capped at 10 (the effective limit is the lesser of this value or 10)."
        }
      ],
      "outputs": [
        {
          "name": "success",
          "type": "boolean",
          "httpStatus": "200"
        },
        {
          "name": "response",
          "type": "object",
          "children": [
            {
              "name": "results",
              "type": "object",
              "multipleValues": true,
              "children": [
                {
                  "name": "tguid",
                  "type": "integer",
                  "description": "Tenant ID (auto-generated identity). Use this as the textbox 'choice values field'.",
                  "httpStatus": "200"
                },
                {
                  "name": "tlname",
                  "type": "string",
                  "description": "Last Name",
                  "httpStatus": "200"
                },
                {
                  "name": "tfname",
                  "type": "string",
                  "description": "First Name",
                  "httpStatus": "200"
                },
                {
                  "name": "tcity",
                  "type": "string",
                  "description": "City",
                  "httpStatus": "200"
                },
                {
                  "name": "tstate",
                  "type": "string",
                  "description": "State Code",
                  "httpStatus": "200"
                },
                {
                  "name": "tzip",
                  "type": "string",
                  "description": "Zip/Postal Code",
                  "httpStatus": "200"
                }
              ],
              "httpStatus": "200"
            }
          ],
          "httpStatus": "200"
        }
      ],
      "httpStatuses": [
        "200"
      ],
      "subcategory": "",
      "steps": [
        {
          "text": "Custom Node.js",
          "answers": {
            "plugin": "Custom:code",
            "custom-code": "console.log(`API Inputs`, input[\"query\"]);\r\nconsole.log(`API Inputs`, input[\"limit\"]);\r\n",
            "comment": ""
          }
        },
        {
          "text": "Get matching records",
          "answers": {
            "plugin": "Database:get-records",
            "connection": "",
            "tables": "TENANTP",
            "columns": "tguid,tlname,tfname,tcity,tstate,tzip",
            "criteria": "(UPPER(TLNAME) LIKE UPPER('%${input[\"query\"]}%')) OR (UPPER(TFNAME) LIKE UPPER('%${input[\"query\"]}%')) OR (UPPER(TADDR1) LIKE UPPER('%${input[\"query\"]}%')) OR (UPPER(TCITY) LIKE UPPER('%${input[\"query\"]}%')) OR (TSSN4 = '${input[\"query\"]}') OR (REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(TPHONE, ' ', ''), '-', ''), '(', ''), ')', ''), '.', ''), '+', '') LIKE '%${input[\"query\"]}%')",
            "add_order_by": true,
            "order_by": "tlname,tfname",
            "limit": "${(parseInt(input[\"limit\"]) < 10) ? input[\"limit\"] : 10}",
            "skip": "0",
            "destination": "API output",
            "api_output": "output[\"response\"][\"results\"]",
            "comment": "",
            "_qualifiedTables": "TENANTP"
          }
        },
        {
          "text": "Custom Node.js",
          "answers": {
            "plugin": "Custom:code",
            "custom-code": "console.log(`API Result`, JSON.stringify(output[\"response\"][\"results\"]));",
            "comment": ""
          }
        }
      ]
    }
