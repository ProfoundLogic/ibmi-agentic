/* Compile with */
/* CRTBNDCL PGM(PLOBJ1/CALLPRC01) SRCFILE(PLSRC1/QCLLESRC) OPTION(*EVENTF) DBGVIEW(*SOURCE) */
PGM
    DCLPRCOPT  BNDDIR(SRVPGMS)

    DCL        VAR(&STRING_ONE) TYPE(*CHAR) LEN(512)
    DCL        VAR(&STRING_TWO) TYPE(*CHAR) LEN(512)
    DCL        VAR(&RESULT) TYPE(*CHAR) LEN(1)

    CHGVAR     VAR(&STRING_ONE) VALUE('HELLO')
    CHGVAR     VAR(&STRING_TWO) VALUE('HELLO')

    CALLPRC    PRC('STREQUAL') +
               PARM((&STRING_ONE) (&STRING_TWO)) RTNVAL(&RESULT)

    SNDPGMMSG  MSG(&RESULT) TOPGMQ(*EXT)
ENDPGM
